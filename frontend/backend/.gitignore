*.key
*.pem
*.crt
*.cer

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Database (for future use)
*.db
*.sqlite

# Secrets
credentials.json
secrets/
